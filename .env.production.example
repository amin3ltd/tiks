TIKS_DOMAIN=tiks.cc
TIKS_CADDY_EMAIL=admin@tiks.cc

POSTGRES_DB=tiks
POSTGRES_USER=tiks
POSTGRES_PASSWORD=change-this-database-password

PRETIX_PRETIX_INSTANCE_NAME=tiks
PRETIX_PRETIX_URL=https://tiks.cc
PRETIX_PRETIX_DATADIR=/data
PRETIX_PRETIX_REGISTRATION=false
PRETIX_PRETIX_CURRENCY=ETB
PRETIX_LOCALE_DEFAULT=en
PRETIX_LOCALE_TIMEZONE=Africa/Addis_Ababa
PRETIX_PRETIX_TRUST_X_FORWARDED_PROTO=true
PRETIX_PRETIX_TRUST_X_FORWARDED_FOR=true
PRETIX_PRETIX_TRUST_X_FORWARDED_HOST=true

PRETIX_DATABASE_BACKEND=postgresql
PRETIX_DATABASE_NAME=tiks
PRETIX_DATABASE_USER=tiks
PRETIX_DATABASE_PASSWORD=change-this-database-password
PRETIX_DATABASE_HOST=db
PRETIX_DATABASE_PORT=5432

PRETIX_REDIS_LOCATION=redis://redis:6379/0
PRETIX_REDIS_SESSIONS=true

PRETIX_CELERY_BROKER=redis://redis:6379/1
PRETIX_CELERY_BACKEND=redis://redis:6379/2

PRETIX_MAIL_FROM=tickets@tiks.cc
PRETIX_MAIL_HOST=smtp.example.com
PRETIX_MAIL_PORT=587
PRETIX_MAIL_USER=change-me
PRETIX_MAIL_PASSWORD=change-me
PRETIX_MAIL_TLS=true

PRETIX_DJANGO_DEBUG=false
